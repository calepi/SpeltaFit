{
  "entities": {
    "User": {
      "title": "User",
      "description": "A registered user of the SpeltaFit app.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "name", "role", "createdAt"]
    },
    "Anamnesis": {
      "title": "Anamnesis",
      "description": "User's physical profile and goals.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "goal": { "type": "string" },
        "secondaryGoal": { "type": "string" },
        "experience": { "type": "string" },
        "daysPerWeek": { "type": "number" },
        "duration": { "type": "number" },
        "limitations": { "type": "string" },
        "cardioPreference": { "type": "string" },
        "equipment": { "type": "string" },
        "sleepQuality": { "type": "string" },
        "stressLevel": { "type": "string" },
        "dietType": { "type": "string" },
        "hormonalStatus": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "age", "gender", "weight", "height", "goal", "experience", "daysPerWeek", "duration", "equipment", "sleepQuality", "stressLevel", "dietType", "hormonalStatus"]
    },
    "WorkoutPlan": {
      "title": "WorkoutPlan",
      "description": "The generated workout plan.",
      "type": "object",
      "properties": {
        "phaseName": { "type": "string" },
        "durationWeeks": { "type": "number" },
        "strategySummary": { "type": "string" },
        "progressiveOverloadPlan": { "type": "string" },
        "monitoringGuidelines": { "type": "string" },
        "weeklyRoutine": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["phaseName", "durationWeeks", "strategySummary", "progressiveOverloadPlan", "monitoringGuidelines", "weeklyRoutine"]
    },
    "WorkoutProgress": {
      "title": "WorkoutProgress",
      "description": "User's tracked progress.",
      "type": "object",
      "properties": {
        "completedSets": { "type": "object" },
        "actualLoads": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["completedSets", "actualLoads", "updatedAt"]
    },
    "NutritionalAnamnesis": {
      "title": "Nutritional Anamnesis",
      "description": "User's nutritional profile and preferences.",
      "type": "object",
      "properties": {
        "mealCount": { "type": "number" },
        "dietType": { "type": "string" },
        "allergies": { "type": "string" },
        "dislikes": { "type": "string" },
        "budget": { "type": "string" },
        "cookingTime": { "type": "string" },
        "supplements": { "type": "array" },
        "waterIntake": { "type": "number" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["mealCount", "dietType", "updatedAt"]
    },
    "DietPlan": {
      "title": "Diet Plan",
      "description": "The generated nutritional plan.",
      "type": "object",
      "properties": {
        "goal": { "type": "string" },
        "calories": { "type": "number" },
        "macros": { "type": "object" },
        "meals": { "type": "array" },
        "supplementation": { "type": "string" },
        "recommendations": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["goal", "calories", "macros", "meals", "createdAt"]
    },
    "NutritionalProgress": {
      "title": "Nutritional Progress",
      "description": "User's tracked nutritional progress.",
      "type": "object",
      "properties": {
        "weight": { "type": "number" },
        "adherence": { "type": "number" },
        "energyLevel": { "type": "string" },
        "digestion": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["weight", "adherence", "updatedAt"]
    },
    "SpeltaGramPost": {
      "title": "SpeltaGram Post",
      "description": "A post in the SpeltaGram community feed.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "caption": { "type": "string" },
        "tag": { "type": "string" },
        "likes": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "imageUrl", "createdAt"]
    },
    "SpeltaGramComment": {
      "title": "SpeltaGram Comment",
      "description": "A comment on a SpeltaGram post.",
      "type": "object",
      "properties": {
        "postId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "userId", "userName", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profile data."
    },
    "/users/{userId}/data/anamnesis": {
      "schema": { "$ref": "#/entities/Anamnesis" },
      "description": "User's current anamnesis."
    },
    "/users/{userId}/data/workoutPlan": {
      "schema": { "$ref": "#/entities/WorkoutPlan" },
      "description": "User's current workout plan."
    },
    "/users/{userId}/data/progress": {
      "schema": { "$ref": "#/entities/WorkoutProgress" },
      "description": "User's current workout progress."
    },
    "/users/{userId}/data/nutritionalAnamnesis": {
      "schema": { "$ref": "#/entities/NutritionalAnamnesis" },
      "description": "User's current nutritional anamnesis."
    },
    "/users/{userId}/data/dietPlan": {
      "schema": { "$ref": "#/entities/DietPlan" },
      "description": "User's current diet plan."
    },
    "/users/{userId}/data/nutritionalProgress": {
      "schema": { "$ref": "#/entities/NutritionalProgress" },
      "description": "User's current nutritional progress."
    },
    "/speltagram_posts/{postId}": {
      "schema": { "$ref": "#/entities/SpeltaGramPost" },
      "description": "Community posts."
    },
    "/speltagram_posts/{postId}/comments/{commentId}": {
      "schema": { "$ref": "#/entities/SpeltaGramComment" },
      "description": "Comments on community posts."
    }
  }
}
